@startuml cluster-schema

skinparam backgroundColor #1a1a2e
skinparam defaultFontColor #e0e0e0
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 13
skinparam shadowing false
skinparam roundCorner 10

skinparam rectangle {
  backgroundColor #16213e
  borderColor #0f3460
  fontColor #e0e0e0
}
skinparam database {
  backgroundColor #16213e
  borderColor #0f3460
  fontColor #e0e0e0
}
skinparam cloud {
  backgroundColor #0f3460
  borderColor #e94560
  fontColor #e0e0e0
}
skinparam node {
  backgroundColor #111827
  borderColor #1e3a5f
  fontColor #e0e0e0
}
skinparam frame {
  backgroundColor #0d1117
  borderColor #1e3a5f
  fontColor #7f8c9b
}
skinparam arrow {
  color #537791
  fontColor #94a3b8
  fontSize 11
}

cloud "  **Internet**  " as inet

node "  **Homelab Node**  //AMD Ryzen 5 2600X · 16 GB DDR4//  " {

  frame "Ingress" {
    rectangle "**Cloudflare Tunnels**" as cf
    rectangle "**MetalLB** \n**Traefik**\n**AdGuard**" as netstack
  }

  frame "Public   *.gabro.ovh" as pubframe {
    rectangle "**Jellyfin**" as jf
    rectangle "**Nextcloud**" as nc
    rectangle "**Immich**" as im
    rectangle "**Navidrome**" as nv
    rectangle "**Authentik**" as auth
    rectangle "**Grafana**" as graf
  }

  frame "Private   *.homelab.arpa" as privframe {
    rectangle "**Servarr**" as sarr
    rectangle "**Prometheus**" as prom
    rectangle "**Headlamp**" as hl
    rectangle "**Peanut**" as pnut
  }

  frame "Data" {
    database "**PostgreSQL**" as pg
    database "**Redis**" as rd
    database "**MinIO**" as s3
  }

  frame "Storage   Longhorn" {
    database "**1TB NVMe** OS" as d1
    database "**500GB NVMe**" as d2
    database "**4TB HDD** Media" as d3
    database "**2TB HDD** Backups" as d4
  }

  rectangle "**Backups**" as bkp
}

rectangle "**UPS 600W**" as ups

' ─── Ordering ───
cf -[hidden]down-> jf
nc -[hidden]down-> sarr
sarr -[hidden]down-> pg
pg -[hidden]down-> d1

' ─── Connections ───
inet -[#e94560,bold]down-> cf : " HTTPS"
cf -[#537791]down-> pubframe
netstack -[#24A1C1]down-> pubframe
netstack -[#24A1C1]down-> privframe

sarr .[#e94560].> jf : " media"
sarr .[#e94560].> nv : " music"
graf -[#F46800]-> prom

nc -[#537791]down-> pg
nc -[#537791]down-> s3
im -[#537791]down-> pg
auth -[#537791]down-> pg

jf -[#537791]down-> d3
sarr -[#537791]down-> d3
bkp -[#7f8c9b]-> d4
bkp .[#7f8c9b].> pg : " dump"
bkp .[#7f8c9b].> s3 : " sync"

ups -[#7f8c9b]-> pnut : " NUT"

@enduml
