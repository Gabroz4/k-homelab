{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":dependencyDashboard",
    ":semanticCommits",
    ":separateMajorReleases"
  ],
  "timezone": "Europe/Rome",
  "schedule": [
    "before 6am on monday"
  ],
  "prHourlyLimit": 0,
  "prConcurrentLimit": 8,
  "labels": [
    "dependencies"
  ],
  "kubernetes": {
    "managerFilePatterns": [
      "/apps/.+\\.ya?ml$/",
      "/infrastructure/.+\\.ya?ml$/"
    ]
  },
  "flux": {
    "managerFilePatterns": [
      "/(^|/)(apps|infrastructure)/.+-helmrelease\\.ya?ml$/",
      "/infrastructure/controllers/sources/helmrepositories\\.ya?ml$/"
    ]
  },
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/apps/pankha/pankha-agent\\.ya?ml$/"
      ],
      "matchStrings": [
        "releases/download/(?<currentValue>v\\d+\\.\\d+\\.\\d+)/pankha-agent-linux_arm64"
      ],
      "depNameTemplate": "Anexgohan/pankha",
      "datasourceTemplate": "github-releases"
    }
  ],
  "packageRules": [
    {
      "matchDatasources": ["docker"],
      "matchUpdateTypes": ["digest"],
      "automerge": true,
      "platformAutomerge": true,
      "automergeStrategy": "squash"
    },
    {
      "matchUpdateTypes": ["patch"],
      "automerge": true,
      "platformAutomerge": true,
      "automergeStrategy": "squash"
    },
    {
      "matchDatasources": ["docker"],
      "matchPackageNames": [
        "lscr.io/linuxserver/sonarr",
        "lscr.io/linuxserver/radarr",
        "lscr.io/linuxserver/prowlarr",
        "lscr.io/linuxserver/lidarr",
        "lscr.io/linuxserver/qbittorrent"
      ],
      "groupName": "servarr stack"
    },
    {
      "matchDatasources": ["docker"],
      "matchPackageNames": ["cloudflare/cloudflared"],
      "groupName": "cloudflared tunnels"
    },
    {
      "matchDatasources": ["docker"],
      "matchPackageNames": [
        "ghcr.io/immich-app/immich-server",
        "ghcr.io/immich-app/immich-machine-learning"
      ],
      "groupName": "immich"
    },
    {
      "matchDatasources": ["docker"],
      "matchPackageNames": ["postgres"],
      "groupName": "postgres clients (backups)",
      "matchUpdateTypes": ["minor", "patch"]
    },
    {
      "matchDatasources": ["docker"],
      "matchPackageNames": ["postgres"],
      "matchUpdateTypes": ["major"],
      "enabled": false
    },
    {
      "matchPackageNames": [
        "nextcloud",
        "tensorchord/cloudnative-pgvecto-rs"
      ],
      "matchUpdateTypes": ["major"],
      "dependencyDashboardApproval": true
    }
  ]
}
